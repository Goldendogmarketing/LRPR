# Google Maps Embed API key for listing map previews.
# Browser-restrict this key to your production domain and localhost during development.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Later, use a server-side Google Geocoding API key to turn real listing addresses into coordinates.
# Keep server geocoding keys private; do not prefix them with NEXT_PUBLIC_.
GOOGLE_MAPS_GEOCODING_API_KEY=

# Supabase/Postgres database connection for submissions, approvals, and published records.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Clerk account validation and protected admin/submission routes.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Stripe paid submission checkout and webhook processing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_STANDARD_LISTING_PRICE_ID=
STRIPE_FEATURED_LISTING_PRICE_ID=
STRIPE_RENTAL_LISTING_PRICE_ID=
STRIPE_ARCHIVE_RECORD_PRICE_ID=
STRIPE_VENDOR_PROFILE_PRICE_ID=

# Resend transactional email notifications.
RESEND_API_KEY=
LRPR_NOTIFICATIONS_FROM=
LRPR_ADMIN_EMAIL=
